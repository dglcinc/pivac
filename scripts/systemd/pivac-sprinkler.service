[Unit]
Description=Pivac OpenSprinkler irrigation flow reader (local HTTP API)
After=network.target signalk.service
Requires=signalk.service

[Service]
Type=simple
User=pi
Environment=PIVAC_CFG=/etc/pivac/config.yml
ExecStart=/home/pi/pivac-venv/bin/python3 /home/pi/github/pivac/scripts/pivac-provider.py pivac.Sprinkler --loglevel WARNING --daemon
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
